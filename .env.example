# 复制为 .env 后修改：cp .env.example .env
# Docker Compose 会自动读取 .env

# 后台 /admin 登录密码（必改，勿使用默认值上线）
ADMIN_PASSWORD=change-me-to-a-strong-password

# 服务监听
HOST=0.0.0.0
PORT=8766

# 数据库（当前为 SQLite 单文件，见 docs/DATABASE.md）
# DATABASE_PATH=/var/lib/codex/card_system.db

# GitHub 版本检查与一键更新（Linux 服务器）
GITHUB_REPO=Aze0920/Codex_Credential_Manager
# ENABLE_SELF_UPDATE=1
# 一键更新必填：宿主机项目绝对路径（docker run -v 用，不能写 /host-codex）
# HOST_BIND_PATH=/www/wwwroot/Codex

# Node（Docker 内默认 /usr/bin/node）
NODE_EXECUTABLE=/usr/bin/node
